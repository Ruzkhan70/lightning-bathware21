rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    
    // System - public read (store config needed for frontend)
    match /system/{document=**} {
      allow read: if true;
      allow write: if isAuth();
    }
    
    // Admins - auth only
    match /admins/{document=**} {
      allow read, write: if isAuth();
    }
    
    // Products in storeData - public read (for storefront), auth write
    match /storeData/{document=**} {
      allow read: if true;
      allow write: if isAuth();
    }
    
    // Admin credentials - auth write (for admin setup)
    match /adminCredentials/{document=**} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    
    // Orders - admins only read, anyone can create
    match /orders/{orderId} {
      allow read: if isAuth();
      allow create: if true;
      allow update, delete: if isAuth();
    }
    
    // Invoices - auth only
    match /invoices/{invoiceId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    
    // Messages - public create, auth read/delete
    match /messages/{messageId} {
      allow read, delete: if isAuth();
      allow create: if true;
    }
    
    // Offers - public read (for storefront), auth write
    match /offers/{offerId} {
      allow read: if true;
      allow write: if isAuth();
    }
    
    // Reviews - public read/create (for storefront), auth update/delete
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAuth();
    }
    
    // Users - auth read, own write
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if true;
      allow update, delete: if isOwner(userId);
    }
    
    // Wishlist - owner only
    match /wishlist/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Carts - owner only
    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Activity Logs - auth only
    match /activityLogs/{logId} {
      allow read, write: if isAuth();
    }
  }
}

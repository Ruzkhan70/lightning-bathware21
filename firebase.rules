rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }
    
    // Products in storeData - public read, auth write
    match /storeData/{document=**} {
      allow read: if true;
      allow write: if isAuth();
    }
    
    // Admin credentials - auth write (for admin setup)
    match /adminCredentials/{document=**} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    
    // Orders - public read, public create, auth update/delete
    match /orders/{orderId} {
      allow read, create: if true;
      allow update, delete: if isAuth();
    }
    
    // Invoices - public read/write
    match /invoices/{invoiceId} {
      allow read, write: if true;
    }
    
    // Messages - public create, auth read/delete
    match /messages/{messageId} {
      allow read, delete: if isAuth();
      allow create: if true;
    }
    
    // Offers - public read, auth write
    match /offers/{offerId} {
      allow read: if true;
      allow write: if isAuth();
    }
    
    // Reviews - public read/create, auth update/delete
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAuth();
    }
    
    // Users - public read/create (for registration), auth update own data
    match /users/{userId} {
      allow read: if true;
      allow create: if true;
      allow update: if isAuth() && request.auth.uid == userId;
      allow delete: if isAuth() && request.auth.uid == userId;
    }
    
    // Wishlist - users can only access their own
    match /wishlist/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }
    
    // Carts - users can only access their own
    match /carts/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }
    
    // Activity Logs - auth read/write
    match /activityLogs/{logId} {
      allow read, write: if isAuth();
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Store profile (public read)
    match /storeData/profile {
      allow read: if true;
      allow write: if false; // Only via admin
    }
    
    // Store assets (public read)
    match /storeData/assets {
      allow read: if true;
      allow write: if false; // Only via admin
    }
    
    // Site content (public read)
    match /storeData/siteContent {
      allow read: if true;
      allow write: if false; // Only via admin
    }
    
    // Products (public read)
    match /storeData/products {
      allow read: if true;
      allow write: if false; // Only via admin
    }
    
    // Categories (public read)
    match /storeData/categories {
      allow read: if true;
      allow write: if false; // Only via admin
    }
    
    // Offers (public read)
    match /storeData/offers {
      allow read: if true;
      allow write: if false; // Only via admin
    }
    
    // Admin credentials (no read access from client)
    match /admin/admin {
      allow read, write: if false;
    }
    
    // Admin profile
    match /admin/profile {
      allow read: if false;
      allow write: if false;
    }
    
    // Orders collection
    match /orders/{orderId} {
      allow read: if true; // Allow customers to view their orders
      allow create: if true; // Allow new orders from checkout
      allow update, delete: if false; // Only admin can modify
    }
    
    // Invoices collection
    match /invoices/{invoiceId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }
    
    // Contact messages
    match /contactMessages/{messageId} {
      allow read: if false;
      allow create: if true;
      allow update, delete: if false;
    }
    
    // User carts (for cart sync feature)
    match /carts/{userId} {
      allow read: if true;
      allow write: if true; // Only authenticated users
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if true;
      allow write: if true; // Users can update their own data
    }
  }
}

# EmailJS Configuration
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
VITE_EMAILJS_TEMPLATE_ID_ADMIN_ORDER=your_admin_order_template_id
VITE_EMAILJS_TEMPLATE_ID_CONTACT=your_contact_template_id

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=1:your_sender_id:web:your_app_id

# Payhere Payment Integration
VITE_PAYHERE_MERCHANT_ID=your_merchant_id
VITE_PAYHERE_MERCHANT_SECRET=your_merchant_secret
VITE_PAYHERE_SANDBOX=true

# Google Analytics (Optional)
VITE_GA_TRACKING_ID=your_ga_tracking_id

# WhatsApp Notifications (Optional)
VITE_WHATSAPP_NOTIFICATIONS=true
VITE_WHATSAPP_ADMIN_PHONE=94771234567

# Online Payment Integration (Future)
# VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_key
# VITE_PAYPAL_CLIENT_ID=your_paypal_client_id

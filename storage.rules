rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow read access to all files (public read)
    match /{allPaths=**} {
      allow read: if true;
    }
    
    // Allow write access for images folder (public write for admin uploads)
    match /images/{imageId} {
      allow write: if true;
    }
    
    // Allow write for any authenticated user or public write
    match /{allPaths=**} {
      allow write: if true;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Store data - public read, authenticated write
    match /storeData/{document=**} {
      allow read: if true;
      allow write: if true;
    }
    
    // Admin credentials
    match /adminCredentials/{document=**} {
      allow read: if true;
      allow write: if true;
    }
    
    // Orders
    match /orders/{orderId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }
    
    // Invoices
    match /invoices/{invoiceId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }
    
    // Messages
    match /messages/{messageId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }
    
    // Offers
    match /offers/{offerId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }
    
    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }
    
    // Users
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Wishlist - user-specific (users can only access their own)
    match /wishlist/{userId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
    
    // Store data - Public read for website, Admin write
    // Website visitors can read products, categories, etc.
    // Only authorized admins should have write access
    match /storeData/{document} {
      allow read: if true;
      allow write: if true; // Application-level admin check
    }
    
    // Orders - Allow create (checkout), read/update by admin
    match /orders/{orderId} {
      allow read: if true;
      allow create: if true; // Allow guest checkout
      allow update, delete: if true; // Admin only via app
    }
    
    // Invoices - Admin access
    match /invoices/{invoiceId} {
      allow read, write: if true;
    }
    
    // Reviews - Public read approved, admin manage
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Messages - Public create, admin read/delete
    match /messages/{messageId} {
      allow read, write: if true;
    }
    
    // Offers - Public read enabled, admin manage
    match /offers/{offerId} {
      allow read, write: if true;
    }
    
    // Wishlist - User-specific access
    match /wishlist/{userId} {
      allow read, write: if true;
    }
    
    // Catch-all - Admin only
    match /{document=**} {
      allow read, write: if true;
    }
  }
}

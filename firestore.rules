rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // System collection - for admin setup tracking
    match /system/{document} {
      allow read: if true;
      allow write: if isAuth();
    }
    
    // Admins collection - check for admin role
    match /admins/{adminId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == adminId;
      allow update, delete: if isAuth() && request.auth.uid == adminId;
    }
    
    // Products in storeData - public read, authenticated write
    match /storeData/{document=**} {
      allow read: if true;
      allow write: if isAuth();
    }
    
    // Admin credentials - authenticated users
    match /adminCredentials/{document=**} {
      allow read, write: if isAuth();
    }
    
    // Admin login logs - anyone can create (for logging)
    match /adminLogs/{logId} {
      allow read: if isAuth();
      allow create: if true;
      allow update, delete: if isAuth();
    }
    
    // Orders - public create (checkout), authenticated read/update
    match /orders/{orderId} {
      allow read: if isAuth();
      allow create: if true;
      allow update, delete: if isAuth();
    }
    
    // Invoices - authenticated only
    match /invoices/{invoiceId} {
      allow read, write: if isAuth();
    }
    
    // Messages - public create (contact form), authenticated read/delete
    match /messages/{messageId} {
      allow read, delete: if isAuth();
      allow create: if true;
    }
    
    // Offers - public read, authenticated write
    match /offers/{offerId} {
      allow read: if true;
      allow write: if isAuth();
    }
    
    // Reviews - public read/create, authenticated update/delete
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAuth();
    }
    
    // Users - public read/create, owner or authenticated update own data
    match /users/{userId} {
      allow read: if true;
      allow create: if true;
      allow update: if isAuth() && (request.auth.uid == userId || isAuth());
      allow delete: if isAuth() && request.auth.uid == userId;
    }
    
    // Wishlist - users can only access their own
    match /wishlist/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }
    
    // Carts - users can only access their own
    match /carts/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }
    
    // Activity Logs - authenticated only
    match /activityLogs/{logId} {
      allow read, write: if isAuth();
    }
    
    // Admin Device Sessions - authenticated only
    match /adminDeviceSessions/{sessionId} {
      allow read, write: if isAuth();
    }
  }
}

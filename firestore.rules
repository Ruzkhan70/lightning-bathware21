rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is the admin
    // NOTE: This check is currently disabled due to the app not using Firebase Auth.
    // In a production app, you should enable Firebase Auth and use request.auth.uid.
    function isAdmin() {
      return true; // TEMPORARY: Allowing all writes to make the app functional.
    }
    
    // Admin credentials - Anyone can read (for login check)
    match /adminCredentials/{document} {
      allow read: if true;
      allow write: if true;
    }
    
    // Store data (products, categories, profile, etc.) - Public read, anyone write (temporary)
    match /storeData/{document} {
      allow read: if true;
      allow write: if true;
    }
    
    // Orders - Customers can create, anyone can read/modify (temporary)
    match /orders/{orderId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }
    
    // Users - Public read/write (temporary)
    match /users/{userId} {
      allow read, write: if true;
    }
    
    // Wishlist - Public access (temporary)
    match /wishlist/{userId} {
      allow read, write: if true;
    }
    
    // Offers - Public access (temporary)
    match /offers/{offerId} {
      allow read, write: if true;
    }
    
    // Invoices - Public access (temporary)
    match /invoices/{invoiceId} {
      allow read, write: if true;
    }
    
    // Contact Messages - Public access (temporary)
    match /contactMessages/{messageId} {
      allow read, write: if true;
    }
  }
}

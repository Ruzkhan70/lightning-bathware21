rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is the admin
    function isAdmin() {
      let storedAdminUid = /databases/$(database)/documents/adminCredentials/main/data.adminUid;
      return request.auth != null && request.auth.uid == storedAdminUid;
    }
    
    // Admin credentials - Anyone can read (for login check)
    // Write allowed if: no admin exists yet OR user is the admin
    match /adminCredentials/{document} {
      allow read: if true;
      allow write: if request.auth != null && (
        resource == null || 
        resource.data.adminUid == request.auth.uid ||
        request.auth.uid == resource.data.adminUid
      );
    }
    
    // Store data (products, categories, profile, etc.) - Public read, admin write
    match /storeData/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Orders - Customers can create, public can read, only admin can modify
    match /orders/{orderId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['customerName', 'phone', 'address', 'products', 'total']);
      allow update, delete: if isAdmin();
    }
    
    // Users - Users can read/write their own data only
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if true;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // Wishlist - Auth required, users can only access their own
    match /wishlist/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Offers - Public read, admin write
    match /offers/{offerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Invoices - Public read (for verification), admin write
    match /invoices/{invoiceId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}

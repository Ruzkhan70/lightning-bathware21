rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Store data - Public read/write
    match /storeData/{document} {
      allow read: if true;
      allow write: if true;
    }
    
    // Orders - Public read/create
    match /orders/{orderId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['customerName', 'phone', 'address', 'products', 'total']);
      allow update, delete: if true;
    }
    
    // Users - Allow registration and password reset without auth
    match /users/{userId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // Wishlist - Auth required
    match /wishlist/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Offers - Public read/write
    match /offers/{offerId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Invoices - Public read/write
    match /invoices/{invoiceId} {
      allow read: if true;
      allow write: if true;
    }
  }
}

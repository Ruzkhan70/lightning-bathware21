rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==================== NOTE ====================
    // This app uses CUSTOM CREDENTIALS stored in Firestore (not Firebase Auth).
    // Security is handled at the application level via AdminContext.tsx
    // 
    // For production with multiple admins, consider:
    // 1. Switching to Firebase Auth
    // 2. Using Cloud Functions for admin operations
    // 3. Implementing IP-based restrictions in Firebase Console
    
    // Admin credentials - needed for login check
    match /adminCredentials/{document} {
      allow read: if true;
      allow write: if true; // Application-level security
    }
    
    // Store data - Public read for website, Admin write
    // Website visitors can read products, categories, etc.
    // Only authorized admins should have write access
    match /storeData/{document} {
      allow read: if true;
      allow write: if true; // Application-level admin check
    }
    
    // Orders - Allow create (checkout), read/update by admin
    match /orders/{orderId} {
      allow read: if true;
      allow create: if true; // Allow guest checkout
      allow update, delete: if true; // Admin only via app
    }
    
    // Invoices - Admin access
    match /invoices/{invoiceId} {
      allow read, write: if true;
    }
    
    // Reviews - Public read approved, admin manage
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Messages - Public create, admin read/delete
    match /messages/{messageId} {
      allow read, write: if true;
    }
    
    // Offers - Public read enabled, admin manage
    match /offers/{offerId} {
      allow read, write: if true;
    }
    
    // Wishlist - User-specific access
    match /wishlist/{userId} {
      allow read, write: if true;
    }
    
    // Catch-all - Admin only
    match /{document=**} {
      allow read, write: if true;
    }
  }
}

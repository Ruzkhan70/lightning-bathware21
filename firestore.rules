rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Admins collection - store admin users
    match /admins/{adminId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == adminId;
      allow update, delete: if false;
    }
    
    // Products in storeData - public read, authenticated write
    match /storeData/{document=**} {
      allow read: if true;
      allow write: if isAuth();
    }
    
    // Admin credentials - authenticated access only
    match /adminCredentials/{document=**} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    
    // Admin login logs - read by admins, anyone can create (for logging)
    match /adminLogs/{logId} {
      allow read: if isAuth();
      allow create: if true;
      allow update, delete: if false;
    }
    
    // Orders - public create (checkout), auth read/update
    match /orders/{orderId} {
      allow read: if isAuth();
      allow create: if true;
      allow update, delete: if isAuth();
    }
    
    // Invoices - auth read/write
    match /invoices/{invoiceId} {
      allow read, write: if isAuth();
    }
    
    // Messages - public create (contact form), auth read/delete
    match /messages/{messageId} {
      allow read, delete: if isAuth();
      allow create: if true;
    }
    
    // Offers - public read, auth write
    match /offers/{offerId} {
      allow read: if true;
      allow write: if isAuth();
    }
    
    // Reviews - public read/create, auth update/delete
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAuth();
    }
    
    // Users - public read/create (registration), auth update own data
    match /users/{userId} {
      allow read: if true;
      allow create: if true;
      allow update: if isAuth() && request.auth.uid == userId;
      allow delete: if isAuth() && request.auth.uid == userId;
    }
    
    // Wishlist - users can only access their own
    match /wishlist/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }
    
    // Carts - users can only access their own
    match /carts/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }
    
    // Activity Logs - auth read/write
    match /activityLogs/{logId} {
      allow read, write: if isAuth();
    }
  }
}
